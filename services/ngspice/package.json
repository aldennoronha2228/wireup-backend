{
  "name": "@wireup/ngspice",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:ngspice:unix": "sh scripts/build-ngspice.sh",
    "build:ngspice:win": "powershell -ExecutionPolicy Bypass -File scripts/build-ngspice.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@wireup/config": "workspace:*",
    "@wireup/utils": "workspace:*",
    "hono": "^4.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.16.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.5"
  }
}
