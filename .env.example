NODE_ENV=production
# LOG_LEVEL is case-insensitive and normalizes to lowercase.
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=45000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
ENABLE_METRICS=true
SERVICE_REQUEST_TIMEOUT_MS=30000
SERVICE_RETRY_COUNT=3
SERVICE_RETRY_DELAY_MS=1000
LLM_PROVIDER=openrouter
LLM_API_KEY=replace-me
LLM_MODEL=anthropic/claude-haiku-4.5
LLM_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
TAVILY_API_KEY=your_tavily_api_key_here
RETRIEVAL_ENABLED=true
USE_FAST_QUERIES=false
GATEWAY_PORT=3000
ORCHESTRATOR_PORT=3001
RAG_PORT=3002
PLANNER_PORT=3003
GENERATOR_PORT=3004
VALIDATOR_PORT=3005
SIMULATOR_PORT=3006
STORAGE_PORT=3007
CONTEXT_BUILDER_PORT=3008
NGSPICE_PORT=3009
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=wireup
MONGODB_MAX_POOL=20
MONGODB_MIN_POOL=2
MONGODB_TIMEOUT_MS=5000
MONGODB_RETRIES=2
RAG_URL=http://rag:3002
CONTEXT_BUILDER_URL=http://context-builder:3008
PLANNER_URL=http://planner:3003
GENERATOR_URL=http://generator:3004
VALIDATOR_URL=http://validator:3005
SIMULATOR_URL=http://simulator:3006
STORAGE_URL=http://storage:3007
ORCHESTRATOR_URL=http://orchestrator:3001
GATEWAY_URL=http://gateway:3000
VELXIO_BASE_URL=http://velxio:8001
VELXIO_COMPILE_URL=http://velxio:8001/api/compile
