{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@wireup/types": ["packages/types/dist/index.d.ts"],
      "@wireup/utils": ["packages/utils/dist/index.d.ts"],
      "@wireup/schemas": ["packages/schemas/dist/index.d.ts"],
      "@wireup/shared": ["packages/shared/dist/index.d.ts"],
      "@wireup/ngspice": ["services/ngspice/dist/index.js"]
    }
  },
  "exclude": ["node_modules"]
}